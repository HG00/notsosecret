[demo]
# Fully-qualified domain name pointing at this host
# Add an A record (IPv4) and/or AAAA record (IPv6) — dual-stack recommended for maximum scanner coverage
domain = www.example.com

# Email address for Let's Encrypt registration and expiry notices
email = you@example.com

# Directory where Zeek writes its logs (run: sudo zeek -i IFACE -C from this dir)
log_dir = .
